<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:controller_auto_show="true"
        app:controller_hide_on_touch="true"
        app:controller_show_timeout="3000"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:show_next_button="false"
        app:show_previous_button="false"
        app:use_controller="true" />

    <LinearLayout
        android:id="@+id/player_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/pip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_player_icon_button"
            android:contentDescription="팝업 재생"
            android:padding="9dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_picture_in_picture"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_player_icon_button"
            android:contentDescription="플레이어 닫기"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_player_close"
            android:tint="#FFFFFF" />
    </LinearLayout>
</FrameLayout>
